MONGO_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/pos
JWT_SECRET=change-me

# Third-party integration — header X-API-Key
CLIENT_SECRET=generate-a-long-random-secret

# Optional: createdBy for integration-created orders
# INTEGRATION_ORDER_CREATED_BY=integration-external

# Behind reverse proxy: use real client IP for rate limits
# TRUST_PROXY=1

# Rate limit overrides (optional; windows in milliseconds)
# RATE_LIMIT_LOGIN_MAX=30
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_REGISTER_MAX=15
# RATE_LIMIT_REGISTER_WINDOW_MS=3600000
# RATE_LIMIT_INTEGRATION_MAX=120
# RATE_LIMIT_INTEGRATION_WINDOW_MS=60000
